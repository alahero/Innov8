{
    "builds": [
        {
            "src": "innov8-website/**/*.php",
            "use": "vercel-php@0.6.2"
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/innov8-website/index.php"
        },
        {
            "source": "/(.*)",
            "destination": "/innov8-website/$1"
        }
    ]
}