RewriteEngine On

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php

RewriteRule ^vendor/ - [R=404,L]

<Files .env>
    Require all denied
</Files>

<FilesMatch "^(composer\.json|composer\.lock)$">
    Require all denied
</FilesMatch>

